---
import "../../styles/global.css";
import data from "../../config/phone_messages.json";

const phone = data.phone_number;
const online_stores = encodeURIComponent(data.online_stores);
const includes_online_stores = encodeURIComponent(data.includes_online_stores);
---

<section
  class="relative h-dvh flex items-center justify-center overflow-hidden"
>
  <div class="container mx-auto px-6 text-center z-20">
    <h1 class="text-4xl md:text-6xl font-bold mb-4 animate-on-scroll">
      Tu pauta trae pedidos. Tu <span class="gradient-text">WhatsApp no da abasto</span> para cobrarlos.
    </h1>
    <p
      class="text-lg md:text-xl max-w-3xl mx-auto text-accent mb-8 animate-on-scroll delay-100"
    >
      Convertimos tu catálogo y el tráfico que ya generas en Instagram en una tienda que vende y cobra sola — para que dejes de gestionar pedidos a mano.
    </p>
    <div class="flex justify-center flex-wrap gap-2 md:gap-0 md:space-x-4 animate-on-scroll delay-200">
      <a href={`https://wa.me/${phone}?text=${online_stores}`} target="_blank" class="btn btn-primary">Diagnóstico gratis · 15 min</a>
      <a href={`https://wa.me/${phone}?text=${includes_online_stores}`} target="_blank" class="btn btn-secondary">Ver qué incluye</a>
    </div>
    <div
      class="flex mt-8 gap-4 md:gap-8 justify-center flex-wrap text-sm text-accent animate-on-scroll delay-300"
    >
      <div>✓ Entrega en 1-3 semanas</div>
      <div>✓ Diseño personalizado</div>
      <div>✓ Sin contratos ni costos ocultos</div>
    </div>
  </div>
</section>