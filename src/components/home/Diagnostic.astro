---
// Diagnostic.astro — Interactive lead-loss calculator
// Webhook URL: set PUBLIC_NOVALUX_DIAGNOSTIC_WEBHOOK_URL in your .env file
import data from "../../config/phone_messages.json";
const phone = data.phone_number;
---

<section id="diagnostico" class="py-20 px-4 md:px-6">
  <div class="container mx-auto max-w-lg">

    <div class="text-center mb-10 animate-on-scroll">
      <p class="text-sm text-primary font-semibold uppercase tracking-wider mb-3">Diagnóstico gratuito</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        ¿Cuántos leads <span class="gradient-text">estás perdiendo?</span>
      </h2>
      <p class="text-accent text-base">3 preguntas. Resultado en 30 segundos.</p>
    </div>

    <div class="diag-card p-6 md:p-8 animate-on-scroll delay-100" id="diagCard">

      <!-- Progress -->
      <div class="diag-progress mb-2" aria-hidden="true">
        <div class="diag-progress-bar" id="diagProgressBar"></div>
      </div>
      <p class="text-xs text-right mb-6" style="color: rgba(181,234,228,0.5)" id="diagStepLabel">Pregunta 1 de 3</p>

      <!-- Q1: mensajes por día -->
      <div class="diag-step" id="diag-step-0">
        <p class="diag-question">¿Cuántos mensajes de clientes recibes al día por Instagram o WhatsApp?</p>
        <div class="diag-options">
          <button class="diag-option" data-step="0" data-value="3">1 – 5 mensajes</button>
          <button class="diag-option" data-step="0" data-value="10">6 – 15 mensajes</button>
          <button class="diag-option" data-step="0" data-value="23">16 – 30 mensajes</button>
          <button class="diag-option" data-step="0" data-value="40">Más de 30</button>
        </div>
      </div>

      <!-- Q2: tiempo de respuesta -->
      <div class="diag-step diag-hidden" id="diag-step-1">
        <p class="diag-question">¿En cuánto tiempo respondes en promedio?</p>
        <div class="diag-options">
          <button class="diag-option" data-step="1" data-value="0.15">Menos de 1 hora</button>
          <button class="diag-option" data-step="1" data-value="0.10">Entre 1 y 4 horas</button>
          <button class="diag-option" data-step="1" data-value="0.05">Entre 4 y 12 horas</button>
          <button class="diag-option" data-step="1" data-value="0.02">Más de 12 horas o al día siguiente</button>
        </div>
      </div>

      <!-- Q3: seguimiento automático -->
      <div class="diag-step diag-hidden" id="diag-step-2">
        <p class="diag-question">¿Tienes algún sistema automático para hacer seguimiento a quienes no respondieron?</p>
        <div class="diag-options">
          <button class="diag-option" data-step="2" data-value="no">No, lo hago manual o no lo hago</button>
          <button class="diag-option" data-step="2" data-value="yes">Sí, tengo automatizaciones activas</button>
        </div>
      </div>

      <!-- Captura de datos -->
      <div class="diag-step diag-hidden" id="diag-step-3">
        <p class="diag-question">Tu resultado está listo. ¿A dónde te lo enviamos?</p>
        <form id="diagForm" novalidate class="mt-4">
          <div class="mb-4">
            <label class="diag-label" for="diagName">Nombre</label>
            <input id="diagName" type="text" class="diag-input" placeholder="Tu nombre" autocomplete="name" required />
          </div>
          <div class="mb-6">
            <label class="diag-label" for="diagContact">WhatsApp o email</label>
            <input id="diagContact" type="text" class="diag-input" placeholder="+57 300... o tu@correo.com" autocomplete="tel" required />
          </div>
          <button type="submit" id="diagSubmitBtn" class="btn btn-primary" style="width:100%">
            Ver mi resultado
          </button>
          <p class="text-xs text-center mt-3" style="color: rgba(181,234,228,0.45)">Sin spam. Solo tu diagnóstico.</p>
        </form>
      </div>

      <!-- Resultado -->
      <div class="diag-step diag-hidden" id="diag-step-4">
        <div class="text-center">
          <p class="text-sm text-primary font-semibold uppercase tracking-wider mb-3">Tu estimado mensual</p>
          <div class="text-7xl font-extrabold mb-2" style="color:#ffffff" id="diagResultNumber">—</div>
          <p class="text-accent mb-6 text-base">leads perdidos por mes por falta de sistema</p>
          <p class="text-sm text-left rounded-xl p-4 mb-6 leading-relaxed" style="background:rgba(28,93,95,0.5); color:rgba(181,234,228,0.85)" id="diagResultInsight"></p>
          <a id="diagResultCTA" href="#" target="_blank" class="btn btn-primary" style="width:100%; display:block">
            Quiero recuperar esos leads
          </a>
          <p class="text-xs mt-4" style="color: rgba(181,234,228,0.45)">Te contactamos en menos de 2 horas</p>
        </div>
      </div>

      <!-- Error de envío (muestra resultado igual) -->
      <div class="diag-step diag-hidden" id="diag-step-error">
        <div class="text-center">
          <div class="text-6xl font-extrabold mb-2" style="color:#ffffff" id="diagResultNumberAlt">—</div>
          <p class="text-accent mb-6">leads perdidos por mes</p>
          <a id="diagResultCTAAlt" href="#" target="_blank" class="btn btn-primary" style="width:100%; display:block">
            Hablar con un asesor
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .diag-card {
    background: rgba(28, 93, 95, 0.4);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(84, 197, 197, 0.2);
    border-radius: 1.5rem;
  }

  .diag-progress {
    height: 4px;
    background: rgba(84, 197, 197, 0.15);
    border-radius: 9999px;
    overflow: hidden;
  }

  .diag-progress-bar {
    height: 100%;
    background: linear-gradient(90deg, #b5eae4, #54c5c5);
    border-radius: 9999px;
    width: 33%;
    transition: width 0.4s ease;
  }

  .diag-question {
    font-size: 1.0625rem;
    font-weight: 600;
    color: #e0f2f1;
    margin-bottom: 1.25rem;
    line-height: 1.55;
  }

  .diag-options {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .diag-option {
    display: block;
    width: 100%;
    min-height: 52px;
    padding: 0.875rem 1.125rem;
    background: rgba(84, 197, 197, 0.07);
    border: 1.5px solid rgba(84, 197, 197, 0.22);
    border-radius: 0.875rem;
    color: #b5eae4;
    font-size: 0.9375rem;
    font-weight: 500;
    text-align: left;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
    font-family: 'Poppins', sans-serif;
    line-height: 1.4;
  }

  .diag-option:hover,
  .diag-option:focus-visible {
    background: rgba(84, 197, 197, 0.18);
    border-color: #54c5c5;
    color: #ffffff;
    outline: none;
  }

  .diag-label {
    display: block;
    font-size: 0.875rem;
    color: #b5eae4;
    margin-bottom: 0.4rem;
    font-weight: 500;
  }

  .diag-input {
    display: block;
    width: 100%;
    min-height: 52px;
    padding: 0.875rem 1rem;
    background: rgba(84, 197, 197, 0.07);
    border: 1.5px solid rgba(84, 197, 197, 0.22);
    border-radius: 0.875rem;
    color: #e0f2f1;
    font-size: 1rem;
    font-family: 'Poppins', sans-serif;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  .diag-input::placeholder {
    color: rgba(181, 234, 228, 0.38);
  }

  .diag-input:focus {
    outline: none;
    border-color: #54c5c5;
  }

  .diag-input.diag-error {
    border-color: #f87171;
  }

  .diag-hidden {
    display: none;
  }
</style>

<script>
  const WEBHOOK_URL: string = (import.meta.env.PUBLIC_NOVALUX_DIAGNOSTIC_WEBHOOK_URL as string) ?? '';
  const PHONE = '573003953980';

  const answers = { msgs: 0, rate: 0, automation: '' };
  let currentStep = 0;

  const STEP_IDS = ['diag-step-0', 'diag-step-1', 'diag-step-2', 'diag-step-3', 'diag-step-4', 'diag-step-error'];
  const PROGRESS = ['33%', '66%', '100%', '100%', '100%', '100%'];
  const LABELS = ['Pregunta 1 de 3', 'Pregunta 2 de 3', 'Pregunta 3 de 3', 'Ya casi…', '', ''];

  function showStep(n: number) {
    STEP_IDS.forEach((id, i) => {
      document.getElementById(id)?.classList.toggle('diag-hidden', i !== n);
    });
    const bar = document.getElementById('diagProgressBar');
    const label = document.getElementById('diagStepLabel');
    if (bar) bar.style.width = PROGRESS[n] ?? '100%';
    if (label) label.textContent = LABELS[n] ?? '';
    currentStep = n;
  }

  function calcLostLeads(): number {
    const IDEAL = 0.15;
    const factor = answers.automation === 'no' ? 1.3 : 1.0;
    return Math.max(Math.round(answers.msgs * 30 * (IDEAL - answers.rate) * factor), 0);
  }

  function buildInsight(lost: number): string {
    const respLabels: Record<string, string> = {
      '0.15': 'menos de 1 hora',
      '0.1': 'entre 1 y 4 horas',
      '0.05': 'entre 4 y 12 horas',
      '0.02': 'más de 12 horas',
    };
    const respLabel = respLabels[String(answers.rate)] ?? 'varias horas';
    if (lost <= 0) {
      return '¡Tu proceso de respuesta es sólido! Aun así, un sistema automatizado puede liberarte de la carga manual diaria y escalar sin añadir personal.';
    }
    const autoMsg = answers.automation === 'no'
      ? 'Sin seguimiento automático, esos leads simplemente se enfrían y compran donde les respondieron primero.'
      : 'Aun con seguimiento, el tiempo de respuesta está costando conversiones valiosas.';
    return `Con ${answers.msgs} mensajes al día y un tiempo de respuesta de ${respLabel}, estás perdiendo aproximadamente ${lost} oportunidades de venta al mes. ${autoMsg}`;
  }

  // Event delegation: handle option clicks
  document.getElementById('diagCard')?.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest<HTMLElement>('.diag-option');
    if (!btn) return;

    const step = Number(btn.dataset.step ?? -1);
    const value = btn.dataset.value ?? '';

    if (step === 0 && currentStep === 0) {
      answers.msgs = Number(value);
      showStep(1);
    } else if (step === 1 && currentStep === 1) {
      answers.rate = Number(value);
      showStep(2);
    } else if (step === 2 && currentStep === 2) {
      answers.automation = value;
      showStep(3);
    }
  });

  // Form submit
  document.getElementById('diagForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const nameEl = document.getElementById('diagName') as HTMLInputElement | null;
    const contactEl = document.getElementById('diagContact') as HTMLInputElement | null;
    const submitBtn = document.getElementById('diagSubmitBtn') as HTMLButtonElement | null;

    if (!nameEl || !contactEl) return;

    nameEl.classList.remove('diag-error');
    contactEl.classList.remove('diag-error');

    let valid = true;
    if (!nameEl.value.trim()) { nameEl.classList.add('diag-error'); valid = false; }
    if (!contactEl.value.trim()) { contactEl.classList.add('diag-error'); valid = false; }
    if (!valid) return;

    if (submitBtn) { submitBtn.textContent = 'Calculando…'; submitBtn.disabled = true; }

    const lost = calcLostLeads();
    const insight = buildInsight(lost);
    const waText = encodeURIComponent(
      `Hola, hice el diagnóstico de leads perdidos en su página y me salió que podría estar perdiendo ${lost} leads al mes. Me gustaría hablar sobre cómo mejorar eso.`
    );
    const waUrl = `https://wa.me/${PHONE}?text=${waText}`;

    const payload = {
      nombre: nameEl.value.trim(),
      contacto: contactEl.value.trim(),
      mensajes_dia: answers.msgs,
      tiempo_respuesta: answers.rate,
      tiene_seguimiento: answers.automation,
      leads_perdidos_estimados: lost,
      fecha: new Date().toISOString(),
    };

    try {
      if (WEBHOOK_URL) {
        await fetch(WEBHOOK_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
      }
      const numEl = document.getElementById('diagResultNumber');
      const insightEl = document.getElementById('diagResultInsight');
      const ctaEl = document.getElementById('diagResultCTA') as HTMLAnchorElement | null;
      if (numEl) numEl.textContent = String(lost);
      if (insightEl) insightEl.textContent = insight;
      if (ctaEl) ctaEl.href = waUrl;
      showStep(4);
    } catch {
      const altNum = document.getElementById('diagResultNumberAlt');
      const altCta = document.getElementById('diagResultCTAAlt') as HTMLAnchorElement | null;
      if (altNum) altNum.textContent = String(lost);
      if (altCta) altCta.href = waUrl;
      showStep(5);
    }
  });
</script>
