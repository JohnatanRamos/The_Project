---
import iconSocialClub from "../../assets/icons_clients/ÍCONO_SOCIAL_CLUB.svg";
import logoBisu from "../../assets/icons_clients/LOGO_BISUMEDELLIN.avif";
import logoLucesLed from "../../assets/icons_clients/logo_luces_led_medellin.webp";
import logoRitmo from "../../assets/icons_clients/LOGO_RITMO.svg";
import logoSegurex from "../../assets/icons_clients/logo_segurex.webp";
import logoServirpro from "../../assets/icons_clients/logo_servirpro.png";
import logoSunnyKids from "../../assets/icons_clients/logos_sunny_kids.webp";

// Los logos "circle" son ícono/insignia circular (mismo ancho y alto);
// se muestran más grandes para igualar el peso visual de los logotipos horizontales.
const clients = [
  { name: "Social Club", image: iconSocialClub, shape: "circle" },
  { name: "Bisu Medellín", image: logoBisu, shape: "circle" },
  { name: "Luces LED Medellín", image: logoLucesLed, shape: "wordmark" },
  { name: "Ritmo Vivo", image: logoRitmo, shape: "circle" },
  { name: "Segurex", image: logoSegurex, shape: "wordmark" },
  { name: "ServirPro Seguros", image: logoServirpro, shape: "wordmark" },
  { name: "Sunny Kids Club", image: logoSunnyKids, shape: "wordmark" },
].map(({ name, image, shape }) => ({ name, src: image.src, shape }));

const imgClass = (shape: string) =>
  shape === "circle"
    ? "max-h-14 sm:max-h-16 w-auto object-contain"
    : "max-h-9 sm:max-h-12 w-auto object-contain";
---

<!-- Clients Section -->
<section id="clients" class="pt-10 py-20 md:pt-20">
    <div class="container mx-auto px-6">
        <!-- <div class="text-center mb-12 animate-on-scroll">
            <h2 class="text-3xl md:text-4xl font-bold">Empresas que <span class="gradient-text">Confían en Nosotros</span></h2>
            <p class="text-lg text-accent mt-2">Impulsando el éxito de líderes en diversas industrias.</p>
        </div> -->
        <div class="glass-card py-8 overflow-hidden animate-on-scroll delay-200 [mask-image:_linear-gradient(to_right,transparent_0,_black_128px,_black_calc(100%-128px),transparent_100%)]">
            <div class="flex w-max animate-scroll-left hover:[animation-play-state:paused]">
                <!-- Logos - Set 1 -->
                <div class="flex-shrink-0 flex items-center justify-center space-x-4 sm:space-x-10 px-3 sm:px-5">
                    {clients.map((client) => (
                        <div class="flex-shrink-0 h-16 sm:h-20 min-w-[5rem] sm:min-w-[8rem] flex items-center justify-center px-3 sm:px-6" title={client.name}>
                            <img src={client.src} alt={client.name} class={imgClass(client.shape)} />
                        </div>
                    ))}
                </div>
                <!-- Logos - Set 2 (Duplicated for seamless loop) -->
                <div class="flex-shrink-0 flex items-center justify-center space-x-4 sm:space-x-10 px-3 sm:px-5" aria-hidden="true">
                    {clients.map((client) => (
                        <div class="flex-shrink-0 h-16 sm:h-20 min-w-[5rem] sm:min-w-[8rem] flex items-center justify-center px-3 sm:px-6">
                            <img src={client.src} alt="" class={imgClass(client.shape)} loading="lazy" />
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>
</section>
