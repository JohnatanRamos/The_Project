---
import data from "../../config/phone_messages.json";

const phone = data.phone_number;
const online_stores = encodeURIComponent(data.online_stores);
---

<section id="precios" class="py-20 pt-10 md:pt-20 bg-secondary/10">
  <div class="container mx-auto px-6">
    <div class="text-center mb-12 animate-on-scroll">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        Inversión en tu <span class="gradient-text">futuro digital</span>
      </h2>
      <p class="text-lg md:text-xl text-accent opacity-90">
        Un solo plan, todo incluido • Sin sorpresas ni letra pequeña
      </p>
    </div>

    <div class="max-w-[700px] mx-auto">
      <div class="pricing-stack">
        <!-- Hero: the price, on its own -->
        <div class="price-hero-frame animate-on-scroll delay-100">
          <div class="price-hero-card">
            <div class="glow-effect"></div>
            <div class="relative z-10">
              <div class="pricing-badge">📲 Tienda Online Completa</div>

              <div class="price-panel">
                <div class="text-xl text-accent mb-2">Inversión de implementación</div>
                <div class="price-figure text-5xl md:text-6xl font-extrabold leading-none mb-2">
                  Desde $4.000.000
                </div>
                <p class="text-accent opacity-80 text-sm md:text-base">
                  Proyecto único — sin mensualidad a Novalux
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Features: individual cards, easy to scan at a glance -->
        <div class="features-section animate-on-scroll delay-200">
          <h4 class="text-lg font-semibold mb-6 text-center text-accent">
            ✨ Todo incluido en tu tienda:
          </h4>
          <ul class="features-grid">
            <li class="feature-chip">
              <span class="feature-check">✓</span>
              <span>Disponible 24/7 para recibir pedidos</span>
            </li>
            <li class="feature-chip">
              <span class="feature-check">✓</span>
              <span>Integración con pasarelas de pago seguras</span>
            </li>
            <li class="feature-chip">
              <span class="feature-check">✓</span>
              <span>Adaptable a cualquier dispositivo</span>
            </li>
            <li class="feature-chip">
              <span class="feature-check">✓</span>
              <span>Panel de control con métricas con Shopify</span>
            </li>
            <li class="feature-chip">
              <span class="feature-check">✓</span>
              <span>Panel fácil de administrar</span>
            </li>
            <li class="feature-chip">
              <span class="feature-check">✓</span>
              <span>Diseño moderno y rápido</span>
            </li>
            <li class="feature-chip">
              <span class="feature-check">✓</span>
              <span>Capacitación en vivo de 2 horas</span>
            </li>
            <li class="feature-chip">
              <span class="feature-check">✓</span>
              <span>Sin contratos ni costos ocultos</span>
            </li>
          </ul>
        </div>

        <!-- Fine print: what can move the price -->
        <div class="variable-note animate-on-scroll delay-300">
          <h4 class="text-base font-semibold mb-4 text-accent">
            💰 El costo de tu tienda online puede variar según:
          </h4>
          <ul class="text-sm md:text-base text-accent opacity-90">
            <li class="variable-item">
              <span class="variable-dot">•</span>
              <span>Nivel de personalización del diseño y funcionalidades especiales</span>
            </li>
            <li class="variable-item">
              <span class="variable-dot">•</span>
              <span>Alcance de la tienda (carrito, envíos, pasarela, etc.)</span>
            </li>
            <li class="variable-item">
              <span class="variable-dot">•</span>
              <span>Páginas y secciones que se incluyan en el desarrollo</span>
            </li>
            <li class="variable-item">
              <span class="variable-dot">•</span>
              <span>Funciones que quieras habilitar en tu tienda online</span>
            </li>
          </ul>
        </div>

        <!-- CTA: its own moment, separate from the info above -->
        <div class="cta-block animate-on-scroll delay-400">
          <a href={`https://wa.me/${phone}?text=${online_stores}`} target="_blank" class="btn btn-primary w-full text-lg">
            Diagnóstico gratis · 15 min
          </a>
          <p class="mt-4 text-sm text-accent opacity-70">
            Sin compromiso — te digo si tu volumen justifica automatizar o no
          </p>
        </div>
      </div>

      <!-- Value Proposition Below -->
      <div class="mt-12 md:mt-16 text-center animate-on-scroll delay-200">
        <h3 class="text-2xl md:text-3xl font-bold mb-6 text-accent">
          💡 ¿Vale la pena la inversión?
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 text-center">
          <div class="stat-card">
            <div class="text-4xl md:text-5xl font-bold text-primary mb-2">
              $3,000+
            </div>
            <p class="text-accent text-sm md:text-base">
              Costo mensual promedio de un vendedor o local físico
            </p>
          </div>
          <div class="stat-card">
            <div class="text-4xl md:text-5xl font-bold text-primary mb-2">
              24/7
            </div>
            <p class="text-accent text-sm md:text-base">
              Tu tienda online vende sin horarios, festivos ni descansos
            </p>
          </div>
          <div class="stat-card">
            <div class="text-4xl md:text-5xl font-bold text-primary mb-2">
              +60%
            </div>
            <p class="text-accent text-sm md:text-base">
              De los consumidores prefieren comprar en línea por comodidad
            </p>
          </div>
        </div>
        <p class="mt-8 text-lg md:text-xl text-accent">
          <strong>En resumen:</strong> Ahorras millones en personal, amplías tu alcance y generas ventas automáticas incluso mientras duermes.
          <span class="text-white font-semibold">Tu tienda se paga sola.</span>
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  /* Vertical rhythm between the independent pricing blocks */
  .pricing-stack {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .pricing-stack {
      gap: 3rem;
    }
  }

  /* Gradient ring wrapper around the hero price card only */
  .price-hero-frame {
    padding: 2px;
    border-radius: 1.75rem;
    background: linear-gradient(
      135deg,
      rgba(84, 197, 197, 0.7),
      rgba(181, 234, 228, 0.15) 45%,
      rgba(84, 197, 197, 0.5)
    );
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
  }

  .price-hero-card {
    position: relative;
    overflow: hidden;
    text-align: center;
    padding: 2rem 1.75rem;
    border-radius: calc(1.75rem - 2px);
    background: rgba(28, 93, 95, 0.4);
    backdrop-filter: blur(10px);
  }

  @media (min-width: 768px) {
    .price-hero-card {
      padding: 2.75rem 3rem;
    }
  }

  .glow-effect {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(
      circle,
      rgba(84, 197, 197, 0.1) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .pricing-badge {
    display: inline-block;
    background: linear-gradient(
      90deg,
      var(--color-primary),
      var(--color-accent)
    );
    color: var(--color-base);
    padding: 0.5rem 1.5rem;
    border-radius: 2rem;
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 2rem;
    box-shadow: 0 6px 20px rgba(84, 197, 197, 0.35);
  }

  /* Highlighted panel around the headline price */
  .price-panel {
    background: rgba(0, 0, 0, 0.18);
    border: 1px solid rgba(84, 197, 197, 0.25);
    border-radius: 1.25rem;
    padding: 1.75rem 1.25rem;
  }

  .price-figure {
    background: linear-gradient(90deg, var(--color-white), var(--color-accent));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Features: no wrapping box — each item is its own small card */
  .features-section {
    text-align: left;
  }

  .features-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
  }

  @media (min-width: 480px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .feature-chip {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    border-radius: 0.875rem;
    background: rgba(28, 93, 95, 0.25);
    border: 1px solid rgba(84, 197, 197, 0.15);
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
  }

  .feature-chip:hover {
    background: rgba(84, 197, 197, 0.14);
    border-color: rgba(84, 197, 197, 0.4);
    transform: translateY(-2px);
  }

  .feature-check {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    color: var(--color-base);
    font-size: 0.8rem;
    font-weight: 700;
  }

  /* Fine print note: deliberately lighter than the features cards above */
  .variable-note {
    border-left: 3px solid var(--color-primary);
    padding: 0.25rem 0 0.25rem 1.25rem;
    text-align: left;
  }

  .variable-note ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .variable-item {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
  }

  .variable-dot {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.375rem;
    height: 1.375rem;
    margin-top: 0.05rem;
    border-radius: 50%;
    background: rgba(84, 197, 197, 0.2);
    color: var(--color-primary);
    font-size: 0.9rem;
    line-height: 1;
  }

  /* CTA: its own step, set apart with a top divider */
  .cta-block {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(84, 197, 197, 0.2);
  }

  /* Value proposition stat cards */
  .stat-card {
    background: rgba(84, 197, 197, 0.06);
    border: 1px solid rgba(84, 197, 197, 0.15);
    border-radius: 1.25rem;
    padding: 1.75rem 1.25rem;
    transition: transform 0.3s ease, border-color 0.3s ease, background 0.3s ease;
  }

  .stat-card:hover {
    transform: translateY(-6px);
    border-color: rgba(84, 197, 197, 0.4);
    background: rgba(84, 197, 197, 0.12);
  }
</style>
